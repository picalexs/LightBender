; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LightBender"
run/main_scene="res://ui/level_selector/level_selector.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Global="*uid://b340w2qoelw87"
BackgroundManager="*uid://iufps20rdm22"
GodotAIBridgeRuntime="*uid://d2q1g4sgk4ffg"
CircleTransition="*res://features/transition/circle_transition.tscn"
MusicManager="*res://features/audio/music_manager.gd"
LevelManager="*res://features/level_manager/level_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/mode=3

[editor]

movie_writer/movie_file="C:/Users/Alex/Documents/Projects/PJ/Proiectarea_Jocurilor/light-bender/output.avi"
movie_writer/disable_vsync=true

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_ai_bridge/plugin.cfg")

